# ── Garmin Connect credentials ────────────────────────────────────────────────
GARMIN_EMAIL=set_me_locally
GARMIN_PASSWORD=set_me_locally

# Your Garmin profileId (NOT the 'id' field — the 'profileId' field from
# /userprofile-service/socialProfile). Found during Stage 1 exploration.
GARMIN_PROFILE_ID=set_me_locally

# ── MQTT broker ───────────────────────────────────────────────────────────────
MQTT_HOST=mosquitto # IP or hostname of your MQTT broker
MQTT_PORT=1883

# Leave blank if your broker has no auth
MQTT_USER=
MQTT_PASSWORD=

# ── MQTT topics ───────────────────────────────────────────────────────────────
# This service publishes new activities to this topic
MQTT_TOPIC_NEW_ACTIVITY=garmin/activity/new

# This service listens for gear selections on this topic
# Node-RED publishes here after the user responds via Telegram
MQTT_TOPIC_GEAR_SELECT=garmin/activity/gear_select

# ── Polling ───────────────────────────────────────────────────────────────────
# How often to check Garmin for new activities, in seconds.
# 300 = every 5 minutes. Lower than 120 is not allowed and will be increased
# to 120 upon start, if attempted.
POLL_INTERVAL=600
